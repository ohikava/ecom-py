[ecom-mcp 14:29:49] ecom_exec(path='/bin/bash', args=['-c', 'python3 << \'PYEOF\'\nfrom collections import defaultdict\nfrom datetime import datetime\n\ndata = []\nwith open(\'/tmp/fraud_data.tsv\') as f:\n    header = None\n    for line in f:\n        line = line.strip()\n        if not line:\n            continue\n        fields = line.split(\'\\t\')\n        if header is None:\n            header = fields\n            continue\n        row = dict(zip(header, fields))\n        data.append(row)\n\nprint(f"Total rows: {len(data)}")\n\n# Pattern analysis\n# Pattern 3: Cross-customer device sharing\ndev_custs = defaultdict(set)\ndev_rows = defaultdict(list)\nfor row in data:\n    dev_custs[row[\'device_fingerprint\']].add(row[\'customer_ref\'])\n    dev_rows[row[\'device_fingerprint\']].append(row)\n\nprint("\\n=== Devices with 3+ customers ===")\nfor dev, custs in sorted(dev_custs.items()):\n    if len(custs) >= 3:\n        times = sorted(datetime.fromisoformat(r[\'created_at\'].replace(\'Z\',\'+00:00\')) for r in dev_rows[dev])\n        span = (times[-1] - times[0]).total_seconds() / 3600\n        print(f"  {dev}: {len(custs)} customers, {len(dev_rows[dev])} rows, span={span:.2f}h")\n        for r in sorted(dev_rows[dev], key=lambda r: r[\'created_at\']):\n            print(f"    {r[\'row_id\']} | {r[\'created_at\']} | {r[\'customer_ref\']} | {r[\'store_city\']} | {r[\'amount_cents\']} | pm={r[\'payment_method_fingerprint\']}")\n\n# Pattern 5: Same (pm,dev) pair across customers\npair_custs = defaultdict(set)\nfor row in data:\n    pair = (row[\'payment_method_fingerprint\'], row[\'device_fingerprint\'])\n    pair_custs[pair].add(row[\'customer_ref\'])\n\nprint("\\n=== (pm,dev) pairs with 2+ customers ===")\nfor pair, custs in sorted(pair_custs.items()):\n    if len(custs) >= 2:\n        pm, dev = pair\n        rows = [r for r in data if r[\'payment_method_fingerprint\'] == pm and r[\'device_fingerprint\'] == dev]\n        print(f"  pm={pm} dev={dev}: {len(custs)} custs, {len(rows)} rows")\n        for r in rows:\n            print(f"    {r[\'row_id\']} | {r[\'created_at\']} | {r[\'customer_ref\']} | {r[\'store_city\']}")\n\n# Pattern 1: Single-customer velocity bursts >=3 cities, span < 30 min\nprint("\\n=== Pattern 1: Single-customer velocity bursts ===")\ncust_groups = defaultdict(list)\nfor row in data:\n    cust_groups[row[\'customer_ref\']].append(row)\n\nfor cust, rows in cust_groups.items():\n    if len(rows) < 3:\n        continue\n    times = sorted(datetime.fromisoformat(r[\'created_at\'].replace(\'Z\',\'+00:00\')) for r in rows)\n    span_min = (times[-1] - times[0]).total_seconds() / 60\n    cities = set(r[\'store_city\'] for r in rows)\n    if len(cities) >= 3 and span_min < 30:\n        print(f"  {cust}: {len(rows)} rows, {len(cities)} cities, span={span_min:.2f} min")\n        for r in sorted(rows, key=lambda r: r[\'created_at\']):\n            print(f"    {r[\'row_id\']} | {r[\'created_at\']} | {r[\'store_city\']} | {r[\'amount_cents\']} | pm={r[\'payment_method_fingerprint\']} dev={r[\'device_fingerprint\']}")\n\n# Broader single-customer bursts (span can be wider but geography impossible)\nprint("\\n=== Single-customer bursts with >=3 cities (any span) ===")\nfor cust, rows in cust_groups.items():\n    cities = set(r[\'store_city\'] for r in rows)\n    if len(cities) >= 3 and len(rows) >= 3:\n        times = sorted(datetime.fromisoformat(r[\'created_at\'].replace(\'Z\',\'+00:00\')) for r in rows)\n        span_h = (times[-1] - times[0]).total_seconds() / 3600\n        if span_h < 24:\n            print(f"  {cust}: {len(rows)} rows, {len(cities)} cities, span={span_h:.2f}h")\n            for r in sorted(rows, key=lambda r: r[\'created_at\']):\n                print(f"    {r[\'row_id\']} | {r[\'created_at\']} | {r[\'store_city\']} | {r[\'amount_cents\']}")\n\nPYEOF\n'], stdin_len=0)
