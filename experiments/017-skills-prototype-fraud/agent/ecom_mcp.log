{len(rows)} rows, {len(cities)} cities, span={span_min:.2f} min\')\n        for r in sorted(rows, key=lambda r: r[\'created_at\']):\n            print(f\'    {r["row_id"]} | {r["created_at"]} | {r["store_city"]} | {r["amount_cents"]} | {r["payment_method_fingerprint"]} {r["device_fingerprint"]}\')\n        # sum\n        total = sum(int(r[\'amount_cents\']) for r in rows)\n        print(f\'    TOTAL: {total} cents = EUR {total/100:.2f}\')\n\n# Pattern 5: same (pm,dev) across customers\nprint(\'\\n=== Pattern 5: (pm,dev) pairs across 2+ customers ===\')\npair_custs = defaultdict(set)\nfor row in data:\n    pair = (row[\'payment_method_fingerprint\'], row[\'device_fingerprint\'])\n    pair_custs[pair].add(row[\'customer_ref\'])\n\nfor pair, custs in sorted(pair_custs.items()):\n    if len(custs) >= 2:\n        pm, dev = pair\n        rows = [r for r in data if r[\'payment_method_fingerprint\'] == pm and r[\'device_fingerprint\'] == dev]\n        print(f\'  pm={pm} dev={dev}: {len(custs)} custs ({sorted(custs)}), {len(rows)} rows\')\n        for r in rows:\n            print(f\'    {r["row_id"]} | {r["created_at"]} | {r["customer_ref"]} | {r["store_city"]} | {r["amount_cents"]}\')\n'], stdin_len=0)
